{
  "name": "mochi-hunt-backend",
  "version": "1.0.0",
  "description": "Mochi Hunt — Express REST API (leaderboard submit/read) with Redis cache, Firebase Admin mirror, and GenLayer anti-cheat",
  "type": "module",
  "main": "server.js",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "firebase-admin": "^12.7.0",
    "genlayer-js": "^1.1.8",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^9.14.0",
    "supertest": "^7.0.0",
    "vitest": "^2.1.4"
  }
