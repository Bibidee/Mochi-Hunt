# ============================================================
#  Mochi Hunt — Environment Configuration (example)
#  Copy to `.env` and fill in real values. NEVER commit `.env`.
# ============================================================

# ---------- Runtime ----------
NODE_ENV=development          # development | test | production
TZ=UTC

# ---------- Backend API ----------
API_HOST=0.0.0.0
API_PORT=4000

# ---------- Frontend (Vite, must be VITE_ prefixed to be exposed) ----------
# Client-side dApp: the browser talks to the GenLayer contract directly via the
# player's wallet. Set this to the deployed mochi_hunt.py (v0.3.0+) address.
VITE_GENLAYER_CONTRACT_ADDRESS=
VITE_APP_NAME=Mochi Hunt

# ---------- CORS ----------
# Comma-separated list of allowed origins for the API
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ---------- Redis (leaderboard read cache) ----------
# Optional in dev — backend falls back to an in-memory cache if unset.
REDIS_URL=redis://localhost:6379
LEADERBOARD_CACHE_TTL_SECONDS=30

# ---------- Rate limiting ----------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60          # max requests per window per IP
SCORE_SUBMIT_MAX_PER_MIN=10

# ---------- GenLayer (integrity source) ----------
# false = local-dev: backend uses deterministic validation only (no chain calls).
# true  = on-chain: backend MUST call the contract; requires the address below
#         or it rejects safely (HTTP 503).
REQUIRE_ONCHAIN_VALIDATION=false
GENLAYER_NETWORK=studionet           # localnet | studionet | testnet (asimov) | bradbury
GENLAYER_RPC_URL=                    # optional; SDK uses the chain default per network
GENLAYER_PRIVATE_KEY=                # backend signing key (KEEP SECRET, you create it)
# Deployed MochiHuntLeaderboard on studionet:
GENLAYER_CONTRACT_ADDRESS=0xCfE8D1bb7d8AA7b488A9Ac23844482AE7D957Cc9

# ---------- Firebase (leaderboard mirror — backend Admin SDK only) ----------
# Optional in dev — backend falls back to an in-memory mirror if unset.
# The frontend NEVER writes Firebase directly.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=                # paste with literal \n for newlines, in quotes
FIREBASE_DATABASE_URL=

# ---------- Logging ----------
LOG_LEVEL=info            # trace | debug | info | warn | error
LOG_PRETTY=true           # pretty-print logs in dev
