# ============================================================
#  Mochi Hunt — Frontend env (example)
#  Fully client-side dApp: the browser talks to the GenLayer contract directly
#  via the player's wallet. There is no backend server.
#  Copy to frontend/.env (Vite reads VITE_* at build time).
# ============================================================

# Deployed mochi_hunt.py address on GenLayer studionet.
VITE_GENLAYER_CONTRACT_ADDRESS=

# Optional display name.
VITE_APP_NAME=Mochi Hunt
